# Copia questo file in ".env" e compila i valori reali.
# IMPORTANTE: ".env" non va MAI committato su git (è già in .gitignore).

# --- Django ---
DJANGO_SECRET_KEY=CAMBIAMI-genera-una-nuova-chiave-vedi-istruzioni
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tuodominio.it,www.tuodominio.it
DJANGO_CSRF_TRUSTED_ORIGINS=https://tuodominio.it,https://www.tuodominio.it

# --- Database (Postgres, es. Neon) ---
DB_NAME=CAMBIAMI
DB_USER=CAMBIAMI
DB_PASSWORD=CAMBIAMI
DB_HOST=CAMBIAMI.neon.tech
DB_PORT=5432
DB_SSLMODE=require

# --- Email (Anymail + Resend, via API HTTP) ---
# Crea una API key su https://resend.com dopo aver verificato il tuo dominio
RESEND_API_KEY=CAMBIAMI-re_xxxxxxxx
DEFAULT_FROM_EMAIL=notifiche@tuodominio.it

# --- iCal esterni (Google Calendar, ecc.), separati da virgola ---
ICAL_EXTERNAL_URLS=https://calendar.google.com/calendar/ical/.../basic.ics

# --- Storage media (Cloudflare R2) ---
# Se lasci queste variabili vuote/assenti, i media vengono salvati sul filesystem
# locale (comodo in sviluppo). In produzione vanno compilate: senza R2_BUCKET_NAME
# tutte le immagini caricate andrebbero perse ad ogni deploy/riavvio del container.
R2_BUCKET_NAME=CAMBIAMI
R2_ACCESS_KEY_ID=CAMBIAMI
R2_SECRET_ACCESS_KEY=CAMBIAMI
R2_ENDPOINT_URL=https://CAMBIAMI.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=pub-CAMBIAMI.r2.dev

# --- Porta su cui gunicorn ascolta dentro il container ---
PORT=8000
